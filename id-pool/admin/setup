#!/bin/bash
# 完全独立の Cognito + Bedrock 環境を構築するスクリプト
# 作成するリソース:
#   1. Cognito User Pool
#   2. Cognito User Pool ドメイン
#   3. Cognito User Pool Client
#   4. Cognito Identity Pool
#   5. IAM ロール（Bedrock 権限付き）
#
# Usage: ADMIN_AWS_PROFILE=your-profile ./setup
set -euo pipefail
export AWS_PAGER=""

PROFILE="${ADMIN_AWS_PROFILE:?環境変数 ADMIN_AWS_PROFILE を設定してください（例: export ADMIN_AWS_PROFILE=genai-poc）}"
REGION="ap-northeast-1"
ACCOUNT_ID=$(aws --profile "$PROFILE" sts get-caller-identity --query Account --output text)

# リソース名
USER_POOL_NAME="claude-code-bedrock"
DOMAIN_PREFIX="cc-bedrock-$(python3 -c "import secrets; print(secrets.token_hex(4))")"
IDENTITY_POOL_NAME="claude-code-bedrock"
ROLE_NAME="BedrockClaudeCodeCognitoRole"
CALLBACK_PORTS=(19240 19336 19427 19777 19819)

echo "=== Claude Code on Bedrock セットアップ ==="
echo "Account: $ACCOUNT_ID"
echo "Region:  $REGION"
echo ""

# -------------------------------------------------------
# 1. Cognito User Pool を作成
# -------------------------------------------------------
echo "[1/5] Cognito User Pool を作成..."
USER_POOL_ID=$(aws --profile "$PROFILE" cognito-idp create-user-pool \
  --pool-name "$USER_POOL_NAME" \
  --username-attributes email \
  --auto-verified-attributes email \
  --policies 'PasswordPolicy={MinimumLength=8,RequireUppercase=true,RequireLowercase=true,RequireNumbers=true,RequireSymbols=false}' \
  --region "$REGION" \
  --no-cli-pager \
  --output text --query "UserPool.Id")

echo "  -> User Pool ID: $USER_POOL_ID"

# -------------------------------------------------------
# 2. Cognito ドメインを設定
# -------------------------------------------------------
echo "[2/5] Cognito ドメインを設定..."
aws --profile "$PROFILE" cognito-idp create-user-pool-domain \
  --user-pool-id "$USER_POOL_ID" \
  --domain "$DOMAIN_PREFIX" \
  --no-cli-pager

COGNITO_DOMAIN="https://${DOMAIN_PREFIX}.auth.${REGION}.amazoncognito.com"
echo "  -> ドメイン: $COGNITO_DOMAIN"

# -------------------------------------------------------
# 3. Cognito User Pool Client を作成
# -------------------------------------------------------
echo "[3/5] Cognito User Pool Client を作成..."
CLIENT_ID=$(aws --profile "$PROFILE" cognito-idp create-user-pool-client \
  --user-pool-id "$USER_POOL_ID" \
  --client-name "claude-code-bedrock" \
  --explicit-auth-flows ALLOW_REFRESH_TOKEN_AUTH \
  --allowed-o-auth-flows code \
  --allowed-o-auth-scopes openid email profile \
  --supported-identity-providers COGNITO \
  --callback-urls $(for p in "${CALLBACK_PORTS[@]}"; do echo "http://localhost:${p}/callback"; done) \
  --logout-urls $(for p in "${CALLBACK_PORTS[@]}"; do echo "http://localhost:${p}/logged-out"; done) \
  --allowed-o-auth-flows-user-pool-client \
  --no-cli-pager \
  --output text --query "UserPoolClient.ClientId")

echo "  -> Client ID: $CLIENT_ID (パブリッククライアント)"

# -------------------------------------------------------
# 4. Cognito Identity Pool を作成
# -------------------------------------------------------
echo "[4/5] Identity Pool を作成..."

PROVIDER_NAME="cognito-idp.${REGION}.amazonaws.com/${USER_POOL_ID}"

IDENTITY_POOL_ID=$(aws --profile "$PROFILE" cognito-identity create-identity-pool \
  --identity-pool-name "$IDENTITY_POOL_NAME" \
  --no-allow-unauthenticated-identities \
  --cognito-identity-providers \
    ProviderName="$PROVIDER_NAME",ClientId="$CLIENT_ID",ServerSideTokenCheck=false \
  --region "$REGION" \
  --no-cli-pager \
  --output text --query "IdentityPoolId")

echo "  -> Identity Pool ID: $IDENTITY_POOL_ID"

# -------------------------------------------------------
# 5. IAM ロールを作成 + Identity Pool にアタッチ
# -------------------------------------------------------
echo "[5/5] IAM ロールを作成..."

TRUST_POLICY=$(cat <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "cognito-identity.amazonaws.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "cognito-identity.amazonaws.com:aud": "$IDENTITY_POOL_ID"
        },
        "ForAnyValue:StringLike": {
          "cognito-identity.amazonaws.com:amr": "authenticated"
        }
      }
    }
  ]
}
EOF
)

ROLE_ARN=$(aws --profile "$PROFILE" iam create-role \
  --role-name "$ROLE_NAME" \
  --assume-role-policy-document "$TRUST_POLICY" \
  --description "Cognito authenticated users role for Bedrock Claude Code" \
  --no-cli-pager \
  --output text --query "Role.Arn")

echo "  -> Role ARN: $ROLE_ARN"

BEDROCK_POLICY=$(cat <<EOF
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:ListInferenceProfiles"
      ],
      "Resource": [
        "arn:aws:bedrock:*:*:inference-profile/*",
        "arn:aws:bedrock:*:*:application-inference-profile/*",
        "arn:aws:bedrock:*:*:foundation-model/*"
      ]
    }
  ]
}
EOF
)

aws --profile "$PROFILE" iam put-role-policy \
  --role-name "$ROLE_NAME" \
  --policy-name "BedrockAccess" \
  --policy-document "$BEDROCK_POLICY" \
  --no-cli-pager

echo "  -> Bedrock 権限ポリシー付与完了"

aws --profile "$PROFILE" cognito-identity set-identity-pool-roles \
  --identity-pool-id "$IDENTITY_POOL_ID" \
  --roles authenticated="$ROLE_ARN" \
  --region "$REGION" \
  --no-cli-pager

echo "  -> Identity Pool にロールをアタッチ完了"

# -------------------------------------------------------
# 結果を env ファイルに保存
# -------------------------------------------------------
cat > "$(dirname "$0")/../env.sh" <<EOF
# setup.sh によって自動生成 ($(date '+%Y/%m/%d %H:%M:%S'))
export COGNITO_USER_POOL_ID="$USER_POOL_ID"
export COGNITO_CLIENT_ID="$CLIENT_ID"
export COGNITO_IDENTITY_POOL_ID="$IDENTITY_POOL_ID"
export COGNITO_PROVIDER_NAME="$PROVIDER_NAME"
export COGNITO_DOMAIN="$COGNITO_DOMAIN"
export COGNITO_DOMAIN_PREFIX="$DOMAIN_PREFIX"
export CALLBACK_PORTS="${CALLBACK_PORTS[*]}"
export AWS_REGION="$REGION"
export IAM_ROLE_NAME="$ROLE_NAME"
EOF

echo ""
echo "=== セットアップ完了 ==="
echo ""
echo "作成されたリソース:"
echo "  User Pool:        $USER_POOL_ID"
echo "  Domain:           $COGNITO_DOMAIN"
echo "  User Pool Client: $CLIENT_ID"
echo "  Identity Pool:    $IDENTITY_POOL_ID"
echo "  IAM Role:         $ROLE_ARN"
echo ""
echo "環境変数を env.sh に保存しました。"
echo ""
echo "次のステップ:"
echo "  1. ユーザを追加:  ./add-user user@example.com"
echo "  2. 動作確認:      ../bedrock-login"
